@article{fareed2025ethical,
  abbr={Published},
  status={published},
  selected={true},
  title={A Systematic Review of Ethical Considerations of Large Language Models in Healthcare and Medicine},
  author={Fareed, Muhammad and Fatima, Madeeha and Uddin, Jamal and Ahmed, Adeel and Sattar, Muhammad Awais},
  journal={Frontiers in Digital Health &middot; IF 3.8 &middot; Q1},
  year={2025},
  publisher={Frontiers},
  doi={10.3389/fdgth.2025.1653631},
  html={https://doi.org/10.3389/fdgth.2025.1653631},
  bibtex_show={true},
  abstract={First author. A PRISMA 2020 systematic review of the ethical risks of deploying large language models in healthcare and medicine — bias, opaque decision-making, privacy leakage, and clinical misinformation. Five databases; 316 records screened; 42 full texts assessed; 27 studies (2017–June 2025) included. Bias and fairness were the most-discussed concern, followed by safety/reliability and transparency. The paper proposes a four-layer ethical integration framework spanning regulatory safeguards, technical safeguards, human oversight, and transparency/accountability.}
}

@article{fareed2026cxrgsvlm,
  abbr={Under Review},
  status={under_review},
  selected={true},
  title={CXRG-SVLM: A Parameter-Efficient Small Vision-Language Model for Multi-View Chest X-ray Report Generation in Resource-Constrained Environments},
  author={Fareed, Muhammad and Uddin, Jamal and Ahmed, Adeel and Sayyid, Abdul Hannan and Sattar, Muhammad Awais},
  journal={Scientific Reports &middot; Under review},
  year={2026},
  bibtex_show={true},
  abstract={First author; MS thesis work. An efficient small vision-language model for automated chest X-ray report generation, built for on-premise, privacy-compliant deployment on modest hardware. Architecture: a frozen RAD-DINO image encoder with a 4-bit quantized Qwen2.5-3B-Instruct language model, adapted using 4-bit QLoRA that trains only 38.1M of 3.9B parameters (0.97% trainable). A multi-view fusion module integrates frontal and lateral radiographs, queried through a continuous latent retrieval mechanism to reduce hallucination. On the Indiana University Chest X-ray dataset: ROUGE-L 0.3116, METEOR 0.2530, macro-averaged clinical entity F1 0.4867; 7.8 seconds per report on a single 16 GB GPU. Honest limitations: single-center dataset; weaker detection of subtle or underrepresented findings.}
}

@article{ahmed2026punjabi,
  abbr={Co-author},
  status={under_review},
  title={Optimizing Multilingual BERT for Punjabi Sentiment Analysis using PEFT Techniques: Balancing Accuracy and Parameter Efficiency},
  author={Ahmed, Adeel and Riaz, Saman and Fareed, Muhammad},
  journal={Computers, Materials & Continua (CMC), Tech Science Press &middot; Under review},
  year={2026},
  bibtex_show={true},
  abstract={Third author (contribution: evaluation, manuscript review and rewriting). The first systematic parameter-efficient fine-tuning benchmark for Punjabi sentiment analysis, comparing six PEFT methods against full fine-tuning on Multilingual BERT. LoRA reached 85% accuracy while training only 1.07% of parameters (best accuracy/efficiency balance); IA-cubed reached 75% at 0.01% trainable parameters (most resource-efficient, suited to edge deployment), versus 90% for full fine-tuning. IF 1.7 (2024); Scopus CiteScore 6.6 (2025).}
}

